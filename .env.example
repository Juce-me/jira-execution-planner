# Auth mode: basic keeps the existing API-token flow; atlassian_oauth enables browser login.
JIRA_AUTH_MODE=basic
APP_ENVIRONMENT_KEY=local

# Jira site
# Required in both auth modes. In OAuth mode this selects the Atlassian cloud site after login.
JIRA_URL=https://your-company.atlassian.net

# Basic credentials (required only for JIRA_AUTH_MODE=basic)
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your-api-token-here

# Atlassian OAuth settings (required only for JIRA_AUTH_MODE=atlassian_oauth)
# Create an OAuth 2.0 (3LO) app in the Atlassian Developer Console.
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Must exactly match the OAuth 2.0 (3LO) callback URL in the Atlassian app.
ATLASSIAN_REDIRECT_URI=http://localhost:5050/api/auth/atlassian/callback
ATLASSIAN_SCOPES=read:me read:jira-work read:jira-user offline_access

# Required for JIRA_AUTH_MODE=atlassian_oauth.
# Generate locally with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET_KEY=

# Required for local OAuth testing because this branch uses a temporary process-local token store.
# Set to true only with APP_ENVIRONMENT_KEY=local or dev.
OAUTH_LOCAL_TOKEN_STORE_ALLOWED=false

# Server settings (optional)
SERVER_PORT=5050
DEBUG_MODE=false
LOG_LEVEL=INFO

# Optional future access-control flag for settings UI (currently no UI gating enforced)
# SETTINGS_ADMIN_ONLY=true
