# Common settings
# Required in both auth modes. In OAuth mode this selects the Atlassian cloud site after login.
JIRA_URL=https://your-company.atlassian.net
APP_ENVIRONMENT_KEY=local

# Auth: Atlassian OAuth 2.0 (3LO)
# DB/OAuth EPM uses this OAuth session for Jira REST reads.
# Home/Townsquare metadata requires the signed-in user to connect a Home token
# in Settings -> Connections after login.
# Create an OAuth 2.0 (3LO) app in the Atlassian Developer Console.
# In the app's Permissions page, add:
# - User identity API: read:me
# - Jira API: read:jira-work, read:jira-user, read:project:jira
# - Jira Software API: read:board-scope:jira-software, read:sprint:jira-software
# Keep offline_access in ATLASSIAN_SCOPES; it is sent in the authorize URL.
JIRA_AUTH_MODE=atlassian_oauth
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:5050/api/auth/atlassian/callback
ATLASSIAN_SCOPES=read:me read:jira-work read:jira-user read:board-scope:jira-software read:sprint:jira-software read:project:jira offline_access
FLASK_SECRET_KEY=
OAUTH_LOCAL_TOKEN_STORE_ALLOWED=true
OAUTH_TOKEN_STORE_PATH=.oauth-token-store.json
OAUTH_TOKEN_STORE_TTL_SECONDS=2592000
# Reserved for future DB-backed first-admin bootstrap.
# Legacy pre-DB OAuth treated every signed-in Atlassian user as a local tool admin.
# TOOL_ADMIN_ATLASSIAN_ACCOUNT_IDS=

# Database-backed auth/config settings
# PostgreSQL is required for production-like local DB auth. SQLite is for unit tests only.
DATABASE_URL=postgresql+psycopg://jep:jep@localhost:5432/jep_local
# TEST_DATABASE_URL=sqlite+pysqlite:///:memory:
CONFIG_STORAGE_BACKEND=db
TOKEN_ENCRYPTION_MASTER_KEY_B64=
TOKEN_ENCRYPTION_KEY_ID=local-dev
# TOKEN_ENCRYPTION_RETIRED_KEY_IDS=
# TOKEN_ENCRYPTION_RETIRED_KEYS_B64=

# Legacy server-side API-token auth remains a separate compatibility mode.
# Do not use those Basic credential settings for the DB/OAuth EPM path.

# Server settings (optional)
SERVER_PORT=5050
APP_BIND_HOST=127.0.0.1
# Set APP_BIND_HOST=0.0.0.0 only when intentionally exposing the app.
# Network bind also requires ALLOW_NETWORK_BIND=true.
# Basic auth network bind additionally requires ALLOW_BASIC_AUTH_ON_NETWORK=true and APP_ENVIRONMENT_KEY=local.
# Dev diagnostics require ALLOW_DEV_DIAGNOSTIC_ENDPOINTS=true and loopback access.
# ALLOW_NETWORK_BIND=false
# ALLOW_BASIC_AUTH_ON_NETWORK=false
# ALLOW_DEV_DIAGNOSTIC_ENDPOINTS=false
DEBUG_MODE=false
LOG_LEVEL=INFO

# Google Analytics 4 / Google Tag Manager
# Keep disabled unless this deployment is approved for internal employee product analytics.
# GA4_ENABLED=false is the single kill switch; leave the IDs configured so it can be re-enabled safely.
GA4_ENABLED=false
GTM_CONTAINER_ID=GTM-NZJW2CFN
GA4_MEASUREMENT_ID=G-6QERX19WB0
GA4_USER_ID_PEPPER=
GA4_DEBUG_MODE=false

# Optional access-control flag for shared configuration writes and settings UI gating.
# SETTINGS_ADMIN_ONLY=true

# Container/internal hosting profile
# Keep this block commented in the template. Set values through the hosting platform,
# secrets manager, or equivalent runtime env injection.
# APP_ENVIRONMENT_KEY=production
# PORT=5050
# APP_BIND_HOST=0.0.0.0
# ALLOW_NETWORK_BIND=true
# JIRA_URL=https://your-company.atlassian.net
# JIRA_AUTH_MODE=atlassian_oauth
# CONFIG_STORAGE_BACKEND=db
# DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
# ATLASSIAN_CLIENT_ID=<from-secret>
# ATLASSIAN_CLIENT_SECRET=<from-secret>
# ATLASSIAN_REDIRECT_URI=<https-origin>/api/auth/atlassian/callback
# ATLASSIAN_SCOPES=read:me read:jira-work read:jira-user read:board-scope:jira-software read:sprint:jira-software read:project:jira offline_access
# SESSION_COOKIE_SECURE=true
# APP_ALLOWED_ORIGINS=<https-origin>
# FLASK_SECRET_KEY=<from-secret>
# TOKEN_ENCRYPTION_KEY_SOURCE=env
# TOKEN_ENCRYPTION_MASTER_KEY_B64=<from-secret>
# TOKEN_ENCRYPTION_KEY_ID=<key-id>
# OAUTH_LOCAL_TOKEN_STORE_ALLOWED=false
# LOCAL_FILE_STATE_ENABLED=false
# SCENARIO_DRAFT_LEGACY_IMPORT_ENABLED=false
# RUN_DB_MIGRATIONS=false
# RUN_DB_MIGRATIONS=true is only for single-instance internal deployments.
# Use a separate release job or init step for migrations before multi-replica rollout.
# GA4_ENABLED=false
