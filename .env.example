# Jira credentials (required)
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your-api-token-here

# Server settings (optional)
SERVER_PORT=5050
DEBUG_MODE=false
LOG_LEVEL=INFO

# Atlassian Home (EPM view)
# ATLASSIAN_EMAIL / ATLASSIAN_API_TOKEN may be left blank if they match JIRA_EMAIL / JIRA_TOKEN.
# ATLASSIAN_CLOUD_ID is the cloudId query parameter from Atlassian Home URLs.
# ROOT_GOAL_KEY is the key of the root goal used to discover sub-goals and projects.
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
ATLASSIAN_CLOUD_ID=
ROOT_GOAL_KEY=

# Optional future access-control flag for settings UI (currently no UI gating enforced)
# SETTINGS_ADMIN_ONLY=true
