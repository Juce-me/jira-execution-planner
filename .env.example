# Common settings
# Required in both auth modes. In OAuth mode this selects the Atlassian cloud site after login.
JIRA_URL=https://your-company.atlassian.net
APP_ENVIRONMENT_KEY=local

# Auth: Atlassian OAuth 2.0 (3LO)
# DB/OAuth EPM uses this OAuth session for Jira REST reads.
# Home/Townsquare metadata requires the signed-in user to connect a Home token
# in Settings -> Connections after login.
# Create an OAuth 2.0 (3LO) app in the Atlassian Developer Console.
# In the app's Permissions page, add:
# - User identity API: read:me
# - Jira API: read:jira-work, read:jira-user, read:project:jira
# - Jira Software API: read:board-scope:jira-software, read:sprint:jira-software
# Keep offline_access in ATLASSIAN_SCOPES; it is sent in the authorize URL.
JIRA_AUTH_MODE=atlassian_oauth
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:5050/api/auth/atlassian/callback
ATLASSIAN_SCOPES=read:me read:jira-work read:jira-user read:board-scope:jira-software read:sprint:jira-software read:project:jira offline_access
FLASK_SECRET_KEY=
OAUTH_LOCAL_TOKEN_STORE_ALLOWED=true
OAUTH_TOKEN_STORE_PATH=.oauth-token-store.json
OAUTH_TOKEN_STORE_TTL_SECONDS=2592000
# Reserved for future DB-backed first-admin bootstrap.
# Pre-DB OAuth treats every signed-in Atlassian user as a local tool admin.
# TOOL_ADMIN_ATLASSIAN_ACCOUNT_IDS=

# Database-backed auth/config settings
# PostgreSQL is required for production-like local DB auth. SQLite is for unit tests only.
DATABASE_URL=postgresql+psycopg://jep:jep@localhost:5432/jep_local
# TEST_DATABASE_URL=sqlite+pysqlite:///:memory:
CONFIG_STORAGE_BACKEND=db
TOKEN_ENCRYPTION_MASTER_KEY_B64=
TOKEN_ENCRYPTION_KEY_ID=local-dev
# TOKEN_ENCRYPTION_RETIRED_KEY_IDS=
# TOKEN_ENCRYPTION_RETIRED_KEYS_B64=

# Legacy server-side API-token auth remains a separate compatibility mode.
# Do not use those Basic credential settings for the DB/OAuth EPM path.

# Server settings (optional)
SERVER_PORT=5050
DEBUG_MODE=false
LOG_LEVEL=INFO

# Optional access-control flag for shared configuration writes and settings UI gating.
# SETTINGS_ADMIN_ONLY=true
