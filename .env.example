# Common settings
# Required in both auth modes. In OAuth mode this selects the Atlassian cloud site after login.
JIRA_URL=https://your-company.atlassian.net
APP_ENVIRONMENT_KEY=local

# Auth option A: Jira API token auth (default)
# Keep this block uncommented for the existing API-token workflow.
# To use OAuth instead, comment this block and uncomment Auth option B.
JIRA_AUTH_MODE=basic
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your-api-token-here

# Auth option B: Atlassian OAuth 2.0 (3LO)
# To use browser login, comment Auth option A above and uncomment this block.
# Create an OAuth 2.0 (3LO) app in the Atlassian Developer Console.
# In the app's Permissions page, add:
# - User identity API: read:me
# - Jira API: read:jira-work, read:jira-user, read:project:jira
# - Jira Software API: read:board-scope:jira-software, read:sprint:jira-software
# Keep offline_access in ATLASSIAN_SCOPES; it is sent in the authorize URL.
# JIRA_AUTH_MODE=atlassian_oauth
# ATLASSIAN_CLIENT_ID=
# ATLASSIAN_CLIENT_SECRET=
# ATLASSIAN_REDIRECT_URI=http://localhost:5050/api/auth/atlassian/callback
# ATLASSIAN_SCOPES=read:me read:jira-work read:jira-user read:board-scope:jira-software read:sprint:jira-software read:project:jira offline_access
# FLASK_SECRET_KEY=
# OAUTH_LOCAL_TOKEN_STORE_ALLOWED=true

# Server settings (optional)
SERVER_PORT=5050
DEBUG_MODE=false
LOG_LEVEL=INFO

# Optional future access-control flag for settings UI (currently no UI gating enforced)
# SETTINGS_ADMIN_ONLY=true
